{
  "name": "family_bet",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "db:init": "wrangler d1 execute family-bet --remote --file=./schema.sql",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "deploy": "npm run db:init && npm run build && wrangler pages deploy dist --project-name family-bet"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "wrangler": "^4.100.0"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
